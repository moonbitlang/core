import {
  "moonbitlang/core/builtin",
  "moonbitlang/core/debug",
}

import {
  "moonbitlang/core/buffer",
  "moonbitlang/core/bench",
} for "test"

options(
  targets: {
    "decode_js.mbt": [ "js" ],
    "decode_nonjs.mbt": [ "not", "js" ],
    "encode_js.mbt": [ "js" ],
    "encode_nonjs.mbt": [ "not", "js" ],
    "is_valid_js.mbt": [ "js" ],
    "is_valid_nonjs.mbt": [ "not", "js" ],
  },
)
